# ── Local development (SQLite — no setup needed) ──────────────────────────────
DATABASE_URL=sqlite:///./pocket_guardian.db

# ── Production (PostgreSQL on Render/Supabase) ─────────────────────────────────
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — add your Vercel URL for production
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
